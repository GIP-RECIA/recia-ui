{
  "name": "@gip-recia/ui",
  "version": "1.0.3",
  "contributors": [
    {
      "name": "Quentin Guillemin",
      "email": "quentin.guillemin@recia.fr",
      "url": "https://github.com/Quentin-Guillemin"
    }
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/GIP-RECIA/recia-ui/tree/main/packages/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GIP-RECIA/recia-ui.git"
  },
  "bugs": {
    "url": "https://github.com/GIP-RECIA/recia-ui/issues"
  },
  "keywords": [
    "gip-recia"
  ],
  "exports": {
    ".": "./src/assets/scss/index.scss",
    "./*": "./src/assets/scss/*",
    "./components": "./src/assets/scss/components/index.scss",
    "./components/*": "./src/assets/scss/components/*",
    "./core": "./src/assets/scss/core/index.scss",
    "./core/*": "./src/assets/scss/core/*",
    "./functions": "./src/assets/scss/functions/index.scss",
    "./functions/*": "./src/assets/scss/functions/*",
    "./layouts": "./src/assets/scss/layouts/index.scss",
    "./layouts/*": "./src/assets/scss/layouts/*",
    "./mixins": "./src/assets/scss/mixins/index.scss",
    "./mixins/*": "./src/assets/scss/mixins/*"
  },
  "files": [
    "src/assets/scss/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "sass --style=compressed --error-css --update src/assets/scss/index.scss dist/recia-style.css",
    "release": "yarn run -T commit-and-tag-version -t 'ui/v' --path . --release-as $1 || echo 'Please specify a version type (yarn run release -- [patch, minor, major])'"
  },
  "peerDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "eslint": "^10.0.2",
    "eslint-plugin-format": "^2.0.1",
    "ress": "^5.0.2",
    "sass": "^1.97.3"
  }
}
